# ============================================================
# Stock Analysis Skill — 环境配置模板
# 复制此文件为 .env 并填写实际值
# ============================================================

# ------------------------------------------------------------
# LLM API 配置（兼容所有 OpenAI 格式接口）
# ------------------------------------------------------------
LLM_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4
LLM_API_KEY=your_api_key_here
LLM_MODEL_ID=glm-4-plus
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# ------------------------------------------------------------
# 数据源配置
# ------------------------------------------------------------
TUSHARE_TOKEN=your_tushare_token_here
AKSHARE_ENABLED=true

# ------------------------------------------------------------
# 并发配置
# MAX_CONCURRENT_TASKS 由系统自动计算：
#   floor(MODEL_API_MAX_CONCURRENCY / TASK_MAX_MODEL_CONCURRENCY)
# 示例：10 / 2 = 5 个任务可同时运行
# ------------------------------------------------------------
MODEL_API_MAX_CONCURRENCY=10
TASK_MAX_MODEL_CONCURRENCY=2
TASK_QUEUE_MAX_SIZE=100

# ------------------------------------------------------------
# 服务配置
# ------------------------------------------------------------
SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# ------------------------------------------------------------
# 存储配置
# ------------------------------------------------------------
TASKS_DIR=./tasks
REPORTS_DIR=./reports
TASK_FILE_RETENTION_DAYS=30

# ------------------------------------------------------------
# 分析配置
# ------------------------------------------------------------
# VaR 计算使用的标准仓位基数（元），不影响实际交易建议
ANALYSIS_CAPITAL_BASE=100000
# Stage 2 多空辩论轮数（0=仅初始分析，不辩论；1-3=辩论轮数）
DEBATE_ROUNDS=2
